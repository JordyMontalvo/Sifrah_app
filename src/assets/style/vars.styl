// breakpoints
m-break  = 767px
d-break  = 768px


// colors
c-gray      = #aaa3a3
c-ligh-gray = #eaebec

c-black = #282828
c-blue  = #0093cb
c-semi-dark-blue  = #001c50
c-dark-blue  = #00112b

c-main-blue   = #086eb6
c-main-green  = #5db02c

c-main-light-green  = #4BB167

c-main-red    = #991920
c-main-golden = #d9ad26

c-main-turk = #4fbbc3

// --- Brand Sifrah (app) ---
c-brand           = #e91e63
c-brand-hover     = #cf1658
c-brand-light     = #fce4ec
c-brand-muted     = rgba(233, 30, 99, 0.12)
c-brand-border    = rgba(233, 30, 99, 0.35)
c-brand-black     = #111111
c-brand-text      = #111111

// Legacy aliases → usar c-brand en estilos nuevos
c-main-purple     = c-brand
c-main-light-purple = c-brand-hover

c-main-green = #326c10

// New Sidebar colors
c-menu-dark-bg = #111111
c-menu-item-bg = #1C1C1C
c-menu-active-pink = #E91E63
c-menu-pink-gradient = linear-gradient(90deg, #fb2a8e 0%, #ff4b91 100%)
c-menu-text-dim = #fff
c-menu-border = #2c2c2c


c-red    = #ef476f
c-orange = #f78c6b
c-yellow = #ffd166
c-green  = #06d6a0

c-ligh-green = #80c700

c-msn = #00B2FF


// layout
_grid()
  display grid
  grid-template-rows auto 1fr auto

_flex()
  display flex
  justify-content space-between
  align-items center

// --- Dark/Light mode variables ---
// Paleta principal
color-primary = #086eb6
color-secondary = #5db02c
color-accent = #f78c6b
color-error = #ef476f
color-success = #06d6a0
color-warning = #ffd166

// Light mode
light-bg = #f7f8fa
light-bg-card = #fff
light-text = #222
light-border = #e0e0e0

// Dark mode
dark-bg = #181a1b
dark-bg-card = #23272f
dark-text = #f1f1f1
dark-border = #333

dark-primary = #4fbbc3

global-font = 'Inter', 'Roboto', 'Montserrat', Arial, sans-serif

// Variable para modo actual
app-bg = light-bg
app-bg-card = light-bg-card
app-text = light-text
app-border = light-border

// Se sobreescriben en modo oscuro
