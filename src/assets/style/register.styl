// Estilos específicos para Register.vue

input[type="checkbox"]:checked
  accent-color #e91e63

.register-button
  // Color de fondo normal
  background #e91e63
  width 460px // Ancho del botón
  height 50px // Altura del botón
  color white // Color del texto
  border none // Sin borde
  cursor pointer // Cambia el cursor al pasar sobre el botón
  transition background 0.3s ease
  border-radius 18px
  margin 8px 0
  transition all 0.3s ease // Transición suave para el hover

  &:hover
    background #cf1658 // Color de fondo al hacer hover

.tab-login
  font-size 15px
  color rgba(137, 136, 141, 1)
  text-decoration none
  padding 10px 20px
  border-bottom solid 2px rgba(137, 136, 141, 1)

  &.active
    color #4b2e12 // marrón oscuro
    border-bottom solid 4px #ffb57a // barra amarilla más gruesa
    font-weight bold
    position relative

    &::after
      content ''
      position absolute
      bottom -4px
      left 50%
      transform translateX(-50%)
      width 100% // Barra que cubre todo el ancho de la pestaña
      height 4px
      background-color #FFD900
      border-radius 2px

@media (min-width: 1260px)
  .tab-login
    display none

@media (max-width: 1260px)
  .logos
    display none

@media (max-width: 1260px)
  .label-register
    margin-left 20px
    // margin-top: 5px;
    white-space nowrap

@media (max-width: 1024px)
  .register-button
    margin-left 0
    margin-right 0
    margin 8px auto
    display block

@media (max-width: 768px)
  .register-button
    width 90%
    max-width 400px
    margin 8px auto

@media (max-width: 480px)
  .register-button
    width 95%
    max-width 350px
    margin 8px auto

@media (max-width: 375px)
  .register-button
    width 95%
    max-width 320px
    margin 8px auto

.alert-message
  background-color #fee
  color #c00
  padding 12px 16px
  border-radius 8px
  border 1px solid #fcc
  margin 12px auto
  font-size 14px
  text-align center
  max-width 280px
  width 100%

// Contenedor para input con icono
.input-container
  position relative
  display block
  width 80%
  max-width 509px
  margin 0
  margin-left auto
  margin-right auto
  padding 0

// Iconos dentro de los campos
.input-icon
  position absolute
  right 18px
  top 50%
  transform translateY(-50%)
  pointer-events none
  color #e91e6382
  font-size 23px
  z-index 10
  margin 0
  padding 0
  width auto
  height auto
  line-height 1
  display inline-block

// Icono de contraseña con cursor pointer
.password-icon
  cursor pointer
  pointer-events auto
  transition color 0.3s ease
  
  &:hover
    color #e91e63

// Ocultar icono nativo del input date y dar funcionalidad al icono personalizado
.date-input
  &::-webkit-calendar-picker-indicator
    display none
    -webkit-appearance none
  
  &::-webkit-inner-spin-button
    display none
    -webkit-appearance none

// Icono de calendario personalizado
.calendar-icon
  cursor pointer
  pointer-events auto
  transition color 0.3s ease
  
  &:hover
    color #e91e63

// Icono de contraseña con cursor pointer
.show-icon
  cursor pointer
  pointer-events auto
  transition color 0.3s ease

  &:hover
    color #e91e63

// Iconos que se desbordan - posicionamiento específico
.overflow-icon
  position absolute
  right 18px
  top 50%
  transform translateY(-50%)
  pointer-events auto
  color #e91e6382
  font-size 23px
  z-index 10

// Ajustar padding de inputs para dar espacio al icono
.input-container .input-register-new
  padding-right 40px
  box-sizing border-box
  width 100%

// En filas de 2 columnas, el contenedor debe ocupar su columna
.form-row
  .input-container
    width 100%
    max-width 250px

// Responsive para iconos
@media (min-width: 1110px) and (max-width: 1199px)
  .input-icon
    right 16px
    font-size 24px
  
  .input-container .input-register-new
    padding-right 43px
  
  .input-container
    width 80%
    max-width 509px
  
  .form-row
    .input-container
      width 100%
      max-width 250px

@media (min-width: 1200px)
  .input-icon
    right 18px
    font-size 23px
  
  .input-container .input-register-new
    padding-right 40px
  
  .input-container
    width 80%
    max-width 509px
  
  .form-row
    .input-container
      width 100%
      max-width 250px

@media (min-width: 769px) and (max-width: 1109px)
  .input-icon
    right 14px
    font-size 23px
  
  .input-container .input-register-new
    padding-right 42px
  
  .input-container
    width 90%
    max-width 400px
  
  .form-row
    .input-container
      width 100%
      max-width 180px

@media (max-width: 768px)
  .input-icon
    right 14px
    font-size 21px
    top 42% !important
    transform translateY(-50%) !important
  
  .overflow-icon
    top 42% !important
    transform translateY(-50%) !important
    font-size 21px
    right 14px
  
  .input-container .input-register-new
    padding-right 35px
  
  .input-container
    width 90%
    max-width 400px
  
  .form-row
    .input-container
      width 100%
      max-width 180px

@media (max-width: 480px)
  .input-icon
    right 12px
    font-size 20px
    top 42% !important
    transform translateY(-50%) !important
  
  .overflow-icon
    top 42% !important
    transform translateY(-50%) !important
    font-size 20px
    right 12px

@media (max-width: 375px)
  .input-icon
    right 10px
  
  .overflow-icon
    right 10px
  
  .input-container .input-register-new
    padding-right 30px
  
  .input-container
    width 95%
    max-width 350px
  
  .form-row
    .input-container
      width 100%
      max-width 100%
    
// Ocultar título del formulario en móvil
@media (max-width: 768px)
  .register-title-form
    display none

// Pantalla de confirmación (registro por patrocinador)
.register-success
  max-width 520px
  margin 0 auto
  padding 24px 16px 32px
  text-align center

.success-icon-wrap
  display flex
  justify-content center
  margin-bottom 16px

.success-icon-circle
  width 72px
  height 72px
  border-radius 50%
  background linear-gradient(135deg, #43a047 0%, #2e7d32 100%)
  display flex
  align-items center
  justify-content center
  box-shadow 0 8px 24px rgba(46, 125, 50, 0.25)

  i
    color #fff
    font-size 2rem

.success-title
  margin 0 0 8px
  font-size 1.75rem
  font-weight 700
  color #2e7d32

.success-subtitle
  margin 0 0 24px
  color #555
  font-size 1rem

.success-user-card
  background linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%)
  border 1px solid #c8e6c9
  border-radius 16px
  padding 20px 16px
  margin-bottom 20px

.success-user-avatar
  width 48px
  height 48px
  margin 0 auto 12px
  border-radius 50%
  background #fff
  border 2px solid #a5d6a7
  display flex
  align-items center
  justify-content center

  i
    color #43a047
    font-size 1.25rem

.success-user-label
  margin 0 0 6px
  color #333
  font-size 0.95rem

.success-user-dni
  margin 0 0 4px
  font-size 1.75rem
  font-weight 700
  color #2e7d32
  letter-spacing 0.5px

.success-user-hint
  margin 0
  color #666
  font-size 0.85rem

.success-info-box
  display flex
  align-items flex-start
  gap 10px
  text-align left
  background #e3f2fd
  border 1px solid #90caf9
  border-radius 12px
  padding 14px 16px
  margin-bottom 24px
  color #1565c0
  font-size 0.92rem
  line-height 1.4

  i
    flex-shrink 0
    margin-top 2px
    font-size 1.1rem

.success-home-btn
  display inline-flex
  align-items center
  justify-content center
  gap 10px
  width 100%
  max-width 460px
  margin 0 auto 16px

.success-session-note
  margin 0 0 24px
  color #666
  font-size 0.88rem
  line-height 1.45
  max-width 420px
  margin-left auto
  margin-right auto

.success-help
  margin-bottom 20px
  padding-top 16px
  border-top 1px solid #eee

  p
    margin 0
    color #777
    font-size 0.9rem
    line-height 1.4

@media (max-width: 768px)
  .register-success
    padding 16px 12px 24px

  .success-title
    font-size 1.5rem

  .success-user-dni
    font-size 1.5rem

  .success-home-btn
    width 90%
    max-width 400px
